// This is your Prisma schema file,
// learn more about it in the docs: https://pris.ly/d/prisma-schema

generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

model Consignor {
  id       Int    @id @default(autoincrement())
  name     String
  address  String?
  city     String?
  district String?
  state    String?
  pincode  String?
  gstin    String?
  phone    String?
  email    String?
  group    String?
  migrationType String? @default("MANUAL")
  addresses Json? @default("[]")
  tradeNames Json? @default("[]")
  legalName  String?
  branch     String? @default("MAIN")
  gcs      GC[]
  
  @@unique([name, branch])
}

model Consignee {
  id       Int    @id @default(autoincrement())
  name     String
  address  String?
  city     String?
  district String?
  state    String?
  pincode  String?
  gstin    String?
  phone    String?
  email    String?
  group    String?
  migrationType String? @default("MANUAL")
  addresses Json? @default("[]")
  tradeNames Json? @default("[]")
  legalName  String?
  branch     String? @default("MAIN")
  
  parentId   Int?
  parent     Consignee? @relation("ConsigneeHierarchy", fields: [parentId], references: [id])
  children   Consignee[] @relation("ConsigneeHierarchy")
  
  gcs      GC[]
  
  @@unique([name, branch])
}

model Vehicle {
  id              Int       @id @default(autoincrement())
  vehicleNumber   String    @unique
  type            String?
  ladenType       String?   @default("Open Body")
  
  // RC Verification Details
  ownerName       String?
  ownerPhone      String?
  ownerPhone2     String?
  makeModel       String?
  fitnessExpiry   DateTime?
  insuranceExpiry DateTime?
  npExpiry        DateTime?
  grossWeight     Int?
  rcStatus        String?
  rcVerified      Boolean   @default(false)

  gdms            GDM[]
  trips           Trip[]
}

model Godown {
  id      Int     @id @default(autoincrement())
  name    String  @unique
  address String?
  manager String?
}

model Unit {
  id        Int    @id @default(autoincrement())
  name      String @unique
  shortName String?
}

model HSNMaster {
  id          Int      @id @default(autoincrement())
  hsnCode     String   @unique
  description String?
  gstRate     Float
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt
}

model Driver {
  id              Int       @id @default(autoincrement())
  licenseNumber   String    @unique
  name            String
  phone           String?
  dob             String?
  bloodGroup      String?
  rto             String?
  status          String?
  validityNt      String?
  validityTr      String?
  vehicleClasses  Json?     @default("[]")
  createdAt       DateTime  @default(now())
  updatedAt       DateTime  @updatedAt
}

model GC {
  id             Int       @id @default(autoincrement())
  gcNumber       String
  branch         String?   @default("MAIN")
  financialYear  String?
  type           String?
  date           DateTime?
  time           String?
  status         String?   @default("Created")
  
  consignorId    Int?
  consignor      Consignor? @relation(fields: [consignorId], references: [id])
  
  consigneeId    Int?
  consignee      Consignee? @relation(fields: [consigneeId], references: [id])
  
  invoiceDate    DateTime?
  invoiceNumber  String?
  privateMark    String?
  invoiceValue   Float?
  godown         String?
  
  ewbNumber      String?
  ewbRawData     Json?
  
  goods          GCItem[]
  
  freightFixed   String?
  freightType    String?
  freightRate    Float?
  freightTotal   Float?
  advancePaid    Float?
  balanceFreight Float?
  freightNote    String?
  
  // Settlement Allocations
  paidToDriver   Float?    @default(0)
  paidToTransport Float?   @default(0)

  gdmId          Int?
  gdm            GDM?      @relation(fields: [gdmId], references: [id])
  
  trackingLogs   GcTrackingLog[]
  
  @@unique([gcNumber, branch])
}

model GCItem {
  id           Int     @id @default(autoincrement())
  gcId         Int
  gc           GC      @relation(fields: [gcId], references: [id])
  articleCount Int?
  units        String?
  hsn          String?
  godown       String?
  description  String?
  weight       Float?
  rate         Float?
  amount       Float?
}

model GcTrackingLog {
  id          Int      @id @default(autoincrement())
  gcId        Int
  gc          GC       @relation(fields: [gcId], references: [id], onDelete: Cascade)
  timestamp   DateTime @default(now())
  actionType  String   // e.g., "EWB_FETCHED", "EWB_REGENERATED", "GDM_LOADED", "DELIVERED"
  description String
  metaData    Json?    // Optional JSON for raw EWB snapshots or vehicle numbers
}

model GDM {
  id            Int       @id @default(autoincrement())
  gdmNumber     String
  branch        String?   @default("MAIN")
  date          DateTime?
  time          String?
  status        String?   @default("Created")
  
  vehicleId     Int?
  vehicle       Vehicle?  @relation(fields: [vehicleId], references: [id])
  driverName    String?
  driverPhone   String?
  startKm       Int?
  
  memoAmount    Float?
  advanceAmount Float?
  balanceAmount Float?
  
  fromLocation  String?
  toName        String?
  deliveryAt    String?
  destination   String? // Keeping this for backward compatibility if needed
  
  cewbNumber    String?
  gcs           GC[]
  
  tripId        Int?
  trip          Trip?     @relation(fields: [tripId], references: [id])
  
  @@unique([gdmNumber, branch])
}

model Trip {
  id              Int       @id @default(autoincrement())
  tripNumber      String    @unique
  date            DateTime?
  status          String?   @default("Active")
  
  vehicleId       Int?
  vehicle         Vehicle?  @relation(fields: [vehicleId], references: [id])
  driverName      String?
  driverPhone     String?
  
  // Financials negotiated per trip
  lorryHire       Float?
  advancePaid     Float?
  balanceAmount   Float?
  
  // Sourcing & Commission Details
  sourcedBy       String?   @default("Direct") // "Direct" or "Broker"
  brokerName      String?
  loadingPayer    String?   @default("Transport") // "Transport", "Lorry Owner", "Consignor"
  loadingCharge   Float?    @default(0)
  commissionAmount Float?   @default(0)
  commissionDetails String?
  
  // Additional grey areas
  additions       Float?    @default(0) // Halting, etc
  deductions      Float?    @default(0) // Damage, Shortage
  remarks         String?
  
  // Settlement Outcomes
  crossingAmount  Float?    @default(0)
  returnAmount    Float?    @default(0)
  settledDate     DateTime?
  
  gdms            GDM[]
  branch          String?   @default("MAIN")
}

model FreightBill {
  id              Int       @id @default(autoincrement())
  billNumber      String    @unique
  date            DateTime?
  transporterName String?
  lorryNumber     String?
  fromLocation    String?
  toLocation      String?
  
  gcNumbers       String?   // Comma separated or JSON
  
  grossFreight    Float?
  advancePaid     Float?
  commission      Float?
  shortage        Float?
  tds             Float?
  netBalance      Float?
  
  paymentMode     String?
  remarks         String?
  status          String?   @default("Created")
  branch          String?   @default("MAIN")
}

model Company {
  id              Int       @id @default(autoincrement())
  gstin           String    @unique
  tradeName       String?
  legalName       String?
  address         String?
  city            String?
  district        String?
  state           String?
  pincode         String?
  phone           String?
  email           String?
  status          String?   @default("Active")
}

model Branch {
  id              Int       @id @default(autoincrement())
  branchCode      String    @unique // e.g., "MAIN", "AP_BNG"
  branchName      String    
  gstin           String?
  legalName       String?
  tradeName       String?
  address         String?
  city            String?
  state           String?
  stateCode       String?   // e.g. "37" for AP, "29" for KA
  pincode         String?
  phone           String?
  email           String?
  logoUrl         String?
  status          String?   @default("Active")
  createdAt       DateTime  @default(now())
  updatedAt       DateTime  @updatedAt
}

model DailyTransaction {
  id          Int      @id @default(autoincrement())
  date        DateTime @default(now())
  type        String   // 'INCOME' or 'EXPENSE'
  category    String   // e.g., 'Fuel', 'Office Supplies', 'Tea/Snacks', 'Salary', 'Other'
  amount      Float
  paymentMode String?  // 'Cash', 'Bank Transfer', 'UPI'
  description String?
  reference   String?  // Bill number, receipt, etc.
  branch      String?  @default("MAIN")
}

model PartyPayment {
  id          Int      @id @default(autoincrement())
  date        DateTime @default(now())
  partyType   String   // 'Consignee' or 'Consignor'
  partyId     Int
  amount      Float
  paymentMode String?  // 'Cash', 'Bank Transfer', 'UPI', 'Cheque'
  reference   String?  // UTR number, etc.
  remarks     String?
  branch      String?  @default("MAIN")
}

model WarehouseInward {
  id             Int      @id @default(autoincrement())
  receiptNo      Int?     @unique
  createdAt      DateTime @default(now())
  ewayBillNo     String?
  consignorName  String
  consigneeName  String
  consigneeCity  String?
  articles       Int
  godownNo       String
  remarks        String?
  branch         String?  @default("MAIN")
}

model ApiUsageLog {
  id        Int      @id @default(autoincrement())
  timestamp DateTime @default(now())
  provider  String   // e.g., "WhiteBooks", "Neon DB", "Google Vision", "Render"
  apiName   String   // e.g., "E-Way Bill Fetch", "RC Verification", "Database Read"
  status    String   // "Success", "Failed"
  cost      Float?   @default(0) // 0 if free, else exact amount in INR
}

model LegacyMaster {
  id          Int      @id @default(autoincrement())
  partyType   String   // "CONSIGNOR" or "CONSIGNEE"
  
  // Excel Data (Old ERP)
  oldId       String?
  oldName     String?
  oldAddress  String?
  oldCity     String?
  oldGstin    String?
  oldPhone    String?
  
  // API Fetched Data
  apiName         String?
  apiAddress      String?
  apiCity         String?
  apiDistrict     String?
  apiState        String?
  apiPincode      String?
  apiAddresses    Json?    @default("[]")
  apiLegalName    String?
  apiTradeNames   Json?    @default("[]")
  
  // Staging Status
  status      String   @default("PENDING") // PENDING, APPROVED, FAILED, MISMATCH
  provider    String?  // "APPYFLOW" or "WHITEBOOKS"
  
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt
}

model UnitMaster {
  id          Int      @id @default(autoincrement())
  category    String
  description String
  code        String
  color       String   @default("slate")
  hsn         String?
  goodsDesc   String?
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt
  
  @@unique([category, description])
}

model AuditLog {
  id          Int      @id @default(autoincrement())
  createdAt   DateTime @default(now())
  userRole    String
  userBranch  String
  action      String
  entity      String
  entityId    String
  details     String?
}

model User {
  id        Int       @id @default(autoincrement())
  username  String    @unique
  pin       String
  role      String    // 'admin' or 'worker'
  permissions Json?   // Checkbox-based specific capabilities
  branch    String    // 'MAIN', 'AP_BNG', or 'ALL'
  status    String    @default("Active")
  sessions  Session[]
}

model Session {
  id         Int      @id @default(autoincrement())
  userId     Int
  user       User     @relation(fields: [userId], references: [id], onDelete: Cascade)
  token      String   @unique
  loginTime  DateTime @default(now())
  lastActive DateTime @default(now())
}
